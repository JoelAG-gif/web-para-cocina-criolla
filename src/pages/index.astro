    <div class="admin-form">
      <div class="admin-form-title">🔧 Información del Restaurante</div>
      <div class="aform-grid">
        <div class="af"><label>Nombre del restaurante</label><input type="text" id="cfg-name" value="${config.name}"></div>
        <div class="af"><label>Teléfono WhatsApp (con código país)</label><input type="text" id="cfg-phone" value="${config.phone}" placeholder="51999999999"></div>
        <div class="af aform-full"><label>Dirección</label><input type="text" id="cfg-addr" value="${config.address}"></div>
        <div class="af aform-full"><label>Horario</label><input type="text" id="cfg-hours" value="${config.hours}" placeholder="Lun–Dom: 12pm – 9pm"></div>
      </div>
      <div class="aform-actions"><button class="abtn abtn-save" onclick="saveConfig()">💾 Guardar Información</button></div>
    </div>
    <div class="admin-form" style="margin-top:1rem">
      <div class="admin-form-title">🔐 Cambiar Contraseña del Panel</div>
      <div class="aform-grid">
        <div class="af"><label>Contraseña actual</label><input type="password" id="cfg-pass-old" placeholder="••••••••"></div>
        <div class="af"><label>Nueva contraseña</label><input type="password" id="cfg-pass-new" placeholder="Mínimo 6 caracteres"></div>
      </div>
      <div class="aform-actions"><button class="abtn abtn-save" onclick="changePass()">🔐 Cambiar Contraseña</button></div>
    </div>`;
