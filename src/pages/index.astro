// ===== IA DESCRIPTION GENERATOR =====
function generateDescriptionAI(){
  const name = document.getElementById('af-name').value.trim();
  const catEl = document.getElementById('af-cat');
  const catText = catEl.options[catEl.selectedIndex]?.text || '';
  if(!name || !catText){ showToast('⚠️ Ingresa nombre y sección antes de generar'); return; }
  let base = `Delicioso ${name}`;
  // add generic hints based on category
  const lc = catText.toLowerCase();
  if(lc.includes('entrada')){
    base += ' como entrada, ideal para abrir el apetito';
  } else if(lc.includes('bebida')){
    base += ' refrescante y perfecto para acompañar tu comida';
  } else if(lc.includes('fondo')||lc.includes('principal')||lc.includes('plato')){
    base += ' con ingredientes frescos y sabor casero';
  } else {
    base += ' preparado con mucho cariño';
  }
  base += ', preparado con ingredientes de la mejor calidad.';
  document.getElementById('af-desc').value = base;
  showToast('🧠 Descripción generada');
}
function handleImgUpload(input){
  const file = input.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = e=>{
    uploadedImgData = e.target.result;
    const prev = document.getElementById('imgPreview');
    prev.innerHTML = `<img src="${uploadedImgData}" alt="preview">`;
  };
  reader.readAsDataURL(file);
}

function saveDish(){
  const name = document.getElementById('af-name').value.trim();
  const price = parseFloat(document.getElementById('af-price').value);
  const cat = document.getElementById('af-cat').value;
  const badge = document.getElementById('af-badge').value;
  const desc = document.getElementById('af-desc').value.trim();
  if(!name || !price || !cat){ showToast('⚠️ Completa nombre, precio y sección'); return; }
  if(editingId){
    const idx = dishes.findIndex(d=>d.id===editingId);

    if(idx>=0){
      dishes[idx] = {...dishes[idx], name, price, cat, badge, desc,
        imgData: uploadedImgData || dishes[idx].imgData};
    }
    showToast('✅ Plato actualizado correctamente');
    cancelEdit();
  } else {
    const newDish = {
      id:'d'+Date.now(), name, price, cat, badge, desc,
      available:true, img:'', imgData: uploadedImgData || ''
    };
    dishes.unshift(newDish);
    showToast('✅ Plato agregado al menú');
    resetForm();
  }
  saveData(); renderDishList(); renderMenu();
}

function cancelEdit(){
  editingId = null;
  uploadedImgData = null;
  document.getElementById('formTitle').textContent = '➕ Agregar Nuevo Plato';
  document.getElementById('saveBtn').textContent = '➕ Agregar Plato';
  document.getElementById('cancelEditBtn').style.display = 'none';
  resetForm();
}
function resetForm(){
  ['af-name','af-price','af-desc'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('af-cat').value='';
  document.getElementById('af-badge').value='';
  document.getElementById('imgPreview').innerHTML='<div class="img-preview-text">📷 Click para subir foto<br><small style="color:var(--border)">JPG, PNG hasta 5MB</small></div>';
  uploadedImgData = null;
}

function editDish(id){
  const d = dishes.find(x=>x.id===id); if(!d) return;
  editingId = id;
  uploadedImgData = null;
  document.getElementById('af-name').value = d.name;
  document.getElementById('af-price').value = d.price;
  document.getElementById('af-cat').value = d.cat;
  document.getElementById('af-badge').value = d.badge || '';
  document.getElementById('af-desc').value = d.desc || '';
  const imgSrc = d.imgData || (IMGS[d.img]||'');
  const prev = document.getElementById('imgPreview');
  prev.innerHTML = imgSrc ? `<img src="${imgSrc}" alt="preview">` : '<div class="img-preview-text">📷 Click para cambiar foto</div>';
  document.getElementById('formTitle').textContent = `✏️ Editando: ${d.name}`;
  document.getElementById('saveBtn').textContent = '💾 Guardar Cambios';
  document.getElementById('cancelEditBtn').style.display = '';
  document.getElementById('addForm').scrollIntoView({behavior:'smooth', block:'start'});
}

function toggleDish(id){
  const d = dishes.find(x=>x.id===id); if(!d) return;
  d.available = !d.available;
  saveData(); renderDishList(); renderMenu();
  showToast(d.available ? `✅ "${d.name}" disponible` : `❌ "${d.name}" marcado como agotado`);
}

function deleteDish(id){
  const d = dishes.find(x=>x.id===id);
  if(!d || !confirm(`¿Eliminar "${d.name}" del menú? Esta acción no se puede deshacer.`)) return;
  dishes = dishes.filter(x=>x.id!==id);
  saveData(); renderDishList(); renderMenu();
  showToast(`🗑️ "${d.name}" eliminado`);
}

function renderDishList(){
  const list = document.getElementById('adminDishList');
  if(!list) return;
  if(!dishes.length){ list.innerHTML='<div style="text-align:center;padding:2rem;color:var(--muted)">No hay platos. ¡Agrega el primero!</div>'; return; }
  list.innerHTML = dishes.map(d=>{
    const imgSrc = d.imgData || (IMGS[d.img]||'');
    const secLabel = sections.find(s=>s.id===d.cat);
    return `<div class="admin-dish-item">
      <div class="adi-img"><img src="${imgSrc}" alt="${d.name}"></div>
      <div class="adi-info">
        <div class="adi-name">${d.name}</div>
        <div class="adi-meta">
          <span class="adi-cat">${secLabel ? secLabel.icon+' '+secLabel.name : d.cat}</span>
          <span class="adi-price">S/. ${d.price}</span>
          <span class="adi-avail ${d.available?'yes':'no'}">${d.available?'✓ Disponible':'✗ Agotado'}</span>
          ${d.badge ? `<span class="adi-cat" style="background:var(--bg3)">${d.badge}</span>` : ''}
        </div>
      </div>
      <div class="adi-actions">
        <button class="adi-btn edit" onclick="editDish('${d.id}')">✏️ Editar</button>
        <button class="adi-btn toggle ${d.available?'':'off'}" onclick="toggleDish('${d.id}')">
          ${d.available ? '❌ Agotar' : '✅ Activar'}
        </button>
        <button class="adi-btn del" onclick="deleteDish('${d.id}')">🗑️</button>
      </div>
    </div>`;
  }).join('');
}

// ===== ADMIN SECCIONES =====
function renderAdminSecciones(body){
  body.innerHTML = `
    <div style="margin-bottom:1.5rem">
      <div style="font-weight:700;font-size:.95rem;color:var(--dark);margin-bottom:.4rem">📋 Secciones del Menú</div>
      <div style="font-size:.8rem;color:var(--muted)">Activa o desactiva secciones según tu menú del día.</div>
    </div>
    <div class="section-list">
      ${sections.map(s=>`
      <div class="section-item">
        <div class="si-left">
          <div class="si-icon">${s.icon}</div>
          <div>
            <div class="si-name">${s.name}</div>
            <div class="si-count">${dishes.filter(d=>d.cat===s.id).length} platos registrados</div>
          </div>
        </div>
        <div class="si-actions">
          <button class="adi-btn toggle ${s.enabled?'':'off'}" onclick="toggleSection('${s.id}')">
            ${s.enabled ? '✓ Activa' : '✗ Oculta'}
          </button>
        </div>
      </div>`).join('')}
    </div>
    <div class="admin-form" style="margin-top:1.5rem">
      <div class="admin-form-title">➕ Agregar Nueva Sección</div>
      <div class="aform-grid">
        <div class="af"><label>Ícono (emoji)</label><input type="text" id="sec-icon" placeholder="🍜" maxlength="2" style="font-size:1.5rem;text-align:center"></div>
        <div class="af"><label>Nombre de la sección</label><input type="text" id="sec-name" placeholder="Ej: Postres"></div>
      </div>
      <div class="aform-actions"><button class="abtn abtn-add" onclick="addSection()">➕ Crear Sección</button></div>
    </div>`;
}

function toggleSection(id){
  const s = sections.find(x=>x.id===id); if(!s) return;
  s.enabled = !s.enabled;
  saveData();
  renderAdminSecciones(document.getElementById('adminBody'));
  renderMenuTabs();
  showToast(s.enabled ? `✅ "${s.name}" activada` : `👁️ "${s.name}" oculta del menú`);
}

function addSection(){
  const icon = document.getElementById('sec-icon').value.trim() || '🍽️';
  const name = document.getElementById('sec-name').value.trim();
  if(!name){ showToast('⚠️ Escribe el nombre de la sección'); return; }
  const id = name.toLowerCase().replace(/\s+/g,'_').replace(/[^a-z0-9_]/g,'');
  if(sections.find(s=>s.id===id)){ showToast('⚠️ Ya existe una sección con ese nombre'); return; }
  sections.push({id, name, icon, enabled:true});
  saveData();
  renderAdminSecciones(document.getElementById('adminBody'));
  renderMenuTabs();
  showToast(`✅ Sección "${name}" creada`);
}

function renderMenuTabs(){
  const tabsEl = document.getElementById('menuTabs');
