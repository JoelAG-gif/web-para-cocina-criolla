let activeCat = 'all';
function renderMenu(){
  const grid = document.getElementById('menuGrid');
  const list = activeCat === 'all' ? dishes : dishes.filter(d=>d.cat===activeCat);
  grid.innerHTML = '';
  if(!list.length){
    grid.innerHTML = '<div class="dish-empty">🍽️ No hay platos en esta sección aún.</div>';
    return;
  }
  list.forEach((d,i)=>{
    const badge = d.badge ? `<span class="dish-badge badge-${d.badge}">${d.badge}</span>` : '';
    const imgSrc = d.imgData || (IMGS[d.img] || '') || '';
    const el = document.createElement('div');
    el.className = 'dish-card reveal' + (d.available ? '' : ' unavailable');
    el.innerHTML = `
      <div class="dish-img">
        ${badge}
        <img src="${imgSrc}" alt="${d.name}" loading="lazy">
      </div>
      <div class="dish-body">
        <div class="dish-name">${d.name}</div>
        <div class="dish-desc">${d.desc}</div>
        <div class="dish-foot">
