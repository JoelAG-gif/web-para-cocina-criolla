function saveConfig(){
  config.name = document.getElementById('cfg-name').value.trim() || config.name;
  config.phone = document.getElementById('cfg-phone').value.trim() || config.phone;
  config.address = document.getElementById('cfg-addr').value.trim() || config.address;
  config.hours = document.getElementById('cfg-hours').value.trim() || config.hours;
  saveData();
  showToast('✅ Información actualizada');
}

function changePass(){
  const old = document.getElementById('cfg-pass-old').value;
  const nuevo = document.getElementById('cfg-pass-new').value;
  if(old !== config.password){ showToast('⚠️ Contraseña actual incorrecta'); return; }
  if(nuevo.length < 6){ showToast('⚠️ La nueva contraseña debe tener mínimo 6 caracteres'); return; }
  config.password = nuevo;
  saveData();
  showToast('🔐 Contraseña actualizada exitosamente');
  document.getElementById('cfg-pass-old').value='';
  document.getElementById('cfg-pass-new').value='';
}

// ===== NAV & UI =====
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('scrolled',window.scrollY>20));
function toggleDrawer(){document.getElementById('drawer').classList.toggle('open')}
function closeDrawer(){document.getElementById('drawer').classList.remove('open')}

let toastTimer;
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),2800);
}

function sendReserva(){
  const name=document.getElementById('fn').value.trim();
  const phone=document.getElementById('fp').value.trim();
  const date=document.getElementById('fd').value;
  const hour=document.getElementById('fh').value;
  const persons=document.getElementById('fp2').value;
  const tipo=document.getElementById('ftipo').value;
  const note=document.getElementById('fnote').value.trim();
  if(!name||!tipo){alert('Por favor completa tu nombre y tipo de pedido.');return}
  let msg=`¡Hola ${config.name}! 🍽️ Quiero hacer una reserva/pedido:\n\n`;
  msg+=`👤 *Nombre:* ${name}\n`;
  if(phone) msg+=`📱 *Teléfono:* ${phone}\n`;
  msg+=`📋 *Tipo:* ${tipo}\n`;
  if(persons) msg+=`👥 *Personas:* ${persons}\n`;
  if(date) msg+=`📅 *Fecha:* ${date}\n`;
  if(hour) msg+=`🕐 *Hora:* ${hour}\n`;
  if(note) msg+=`🍴 *Pedido:* ${note}\n`;
  msg+=`\n¿Pueden confirmar? ¡Gracias!`;
  window.open('https://wa.me/'+config.phone+'?text='+encodeURIComponent(msg),'_blank');
  showToast('✓ Redirigiendo a WhatsApp...');
}

// Scroll reveal
const obs=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('visible');obs.unobserve(x.target)}})},{threshold:.08});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// Init
renderMenu();

// ===== CART STATE =====
let cart = [];
let deliveryType = 'local';

function openCart(){ 
  document.getElementById('cartDrawer').classList.add('open');
  document.getElementById('cartBackdrop').classList.add('open');
  renderCart();
  // ensure delivery/time fields are in sync
  const sel = document.querySelector('.ds-opt.selected');
  if(sel) selectDeliveryType(sel, deliveryType);

}
function closeCart(){
  document.getElementById('cartDrawer').classList.remove('open');
  document.getElementById('cartBackdrop').classList.remove('open');
}

function selectDeliveryType(el, type){
  document.querySelectorAll('.ds-opt').forEach(x=>x.classList.remove('selected'));
  el.classList.add('selected');
  deliveryType = type;
  const af = document.getElementById('addrField');
  af.classList.toggle('show', type==='delivery');
  const tf = document.getElementById('timeField');
  const tg = document.getElementById('timeFieldGrid');
  const dateInput = document.getElementById('cartDate');
  const timeInput = document.getElementById('cartTime');
  
  if(type==='local'){
    tf.classList.add('show');
    tg.classList.remove('full');
    dateInput.style.display='block';
    timeInput.style.display='block';
  } else if(type==='recoger'){
    tf.classList.add('show');
    tg.classList.add('full');
    dateInput.style.display='none';
    timeInput.style.display='block';
  } else {
    tf.classList.remove('show');
  }
}

function addToCart(id){
  const dish = dishes.find(d=>d.id===id); if(!dish||!dish.available) return;
  const existing = cart.find(c=>c.id===id);
  if(existing){ existing.qty++; }
  else { cart.push({id, name:dish.name, price:dish.price, qty:1, imgData:dish.imgData||(IMGS[dish.img]||'')}); }
  updateCartUI();
  showToast(`🛒 "${dish.name}" agregado al pedido`);
}

function removeFromCart(id){
  cart = cart.filter(c=>c.id!==id);
  updateCartUI();
  if(document.getElementById('cartDrawer').classList.contains('open')) renderCart();
}

function changeQty(id, delta){
  const item = cart.find(c=>c.id===id); if(!item) return;
  item.qty += delta;
  if(item.qty <= 0){ cart = cart.filter(c=>c.id!==id); }
  updateCartUI();
  renderCart();
}

function getCartTotal(){ return cart.reduce((s,c)=>s+c.price*c.qty, 0); }
function getCartCount(){ return cart.reduce((s,c)=>s+c.qty, 0); }

function updateCartUI(){
  const count = getCartCount();
  const total = getCartTotal();
  // FAB
  const fab = document.getElementById('cartFab');
  fab.classList.toggle('visible', count>0);
  document.getElementById('cartFabBadge').textContent = count;
  // Drawer header
  document.getElementById('cartCountBadge').textContent = count + ' producto' + (count!==1?'s':'');
  // Footer totals
  document.getElementById('cartSubtotal').textContent = 'S/. '+total.toFixed(2);
  document.getElementById('cartTotal').textContent = 'S/. '+total.toFixed(2);
  document.getElementById('cartItemCount').textContent = count + ' producto' + (count!==1?'s':'');
  // WA button
  document.getElementById('cartWaBtn').disabled = count===0;
  // Update dish buttons in menu
  document.querySelectorAll('[data-dish-id]').forEach(el=>{
    const id = el.dataset.dishId;
    const item = cart.find(c=>c.id===id);
    const qtyEl = el.closest('.dish-card')?.querySelector('.dish-qty');
    if(qtyEl){
      if(item && item.qty>0){
        qtyEl.style.display='flex';
        const nEl = qtyEl.querySelector('.dq-n');
        if(nEl) nEl.textContent = item.qty;
      } else if(qtyEl){
        qtyEl.style.display='none';
      }
    }
  });
}

function renderCart(){
  const container = document.getElementById('cartItems');
  if(cart.length===0){
    container.innerHTML='<div class="cart-empty"><div class="cart-empty-icon">🍽️</div><div class="cart-empty-text">Tu pedido está vacío</div><div class="cart-empty-sub">Agrega platos desde el menú</div></div>';
    return;
  }
  container.innerHTML = cart.map(item=>`
    <div class="cart-item">
      <div class="ci-img"><img src="${item.imgData||''}" alt="${item.name}"></div>
      <div class="ci-info">
        <div class="ci-name">${item.name}</div>
        <div class="ci-price">S/. ${item.price.toFixed(2)} c/u</div>
      </div>
      <div class="ci-controls">
        <button class="ci-qty-btn" onclick="changeQty('${item.id}',-1)">−</button>
        <div class="ci-qty">${item.qty}</div>
        <button class="ci-qty-btn" onclick="changeQty('${item.id}',1)">+</button>
        <span class="ci-remove" onclick="removeFromCart('${item.id}')">✕</span>
      </div>
      <div class="ci-total">S/. ${(item.price*item.qty).toFixed(2)}</div>
    </div>`).join('');
}

function sendCartWA(){
  const name = document.getElementById('cartName').value.trim();
  const phone = document.getElementById('cartPhone').value.trim();
  const note = document.getElementById('cartNote').value.trim();
  const addr = document.getElementById('deliveryAddr')?.value.trim();
  if(!name){ showToast('⚠️ Ingresa tu nombre para continuar'); document.getElementById('cartName').focus(); return; }
  if(cart.length===0){ showToast('⚠️ Tu carrito está vacío'); return; }
  if(deliveryType==='delivery' && !addr){ showToast('⚠️ Ingresa tu dirección de delivery'); document.getElementById('deliveryAddr').focus(); return; }
  
  const dateVal = document.getElementById('cartDate')?.value;
  const timeVal = document.getElementById('cartTime')?.value;
  let timeStr = '';
  
  if(deliveryType==='local' && dateVal && timeVal){
    timeStr = `📅 *Reserva para:* ${dateVal} a las ${timeVal}`;
  } else if(deliveryType==='recoger' && timeVal){
    timeStr = `🕒 *Hora de recojo:* ${timeVal}`;
  }

  const typeLabels = {local:'🍽️ Comer en el local', delivery:'🛵 Delivery a domicilio', recoger:'🏃 Recoger en tienda'};
  let msg = `¡Hola ${config.name}! 😊 Quiero hacer un pedido:

`;
  msg += `👤 *Cliente:* ${name}
`;
  if(phone) msg += `📱 *Teléfono:* ${phone}
`;
  msg += `📋 *Tipo:* ${typeLabels[deliveryType]}
`;
  if(deliveryType==='delivery' && addr) msg += `📍 *Dirección:* ${addr}
`;
  if(timeStr) msg += `${timeStr}
`;
  msg += `
🍴 *Mi pedido:*
`;
  cart.forEach(item=>{ msg += `  • ${item.qty}x ${item.name} — S/. ${(item.price*item.qty).toFixed(2)}
`; });
  msg += `
💰 *Total: S/. ${getCartTotal().toFixed(2)}*
`;
  if(note) msg += `
📝 *Nota:* ${note}
`;
  msg += `
¿Pueden confirmar mi pedido? ¡Gracias! 🙏`;

  window.open('https://wa.me/'+config.phone+'?text='+encodeURIComponent(msg),'_blank');
  showToast('✓ Pedido enviado por WhatsApp');
}

// ===== PATCH renderMenu to add cart buttons =====
const _origRenderMenu = renderMenu;
renderMenu = function(){
  _origRenderMenu();
  // After rendering, patch dish buttons
  document.querySelectorAll('.dish-card').forEach(card=>{
    const btn = card.querySelector('.dish-btn');
    if(!btn) return;
    // Get dish id from onclick or find by name
    const dishName = card.querySelector('.dish-name')?.textContent;
    const dish = dishes.find(d=>d.name===dishName);
    if(!dish || !dish.available) return;
    const foot = card.querySelector('.dish-foot');
    if(!foot) return;
    // Replace "Pedir" link with add-to-cart
    btn.remove();
    const cartBtn = document.createElement('button');
    cartBtn.className = 'dish-add-btn';
    cartBtn.dataset.dishId = dish.id;
    cartBtn.innerHTML = '🛒 Agregar';
    cartBtn.onclick = ()=>addToCart(dish.id);
    foot.appendChild(cartBtn);
    // Add qty controls
    const qtyEl = document.createElement('div');
    qtyEl.className = 'dish-qty';
    const inCart = cart.find(c=>c.id===dish.id);
    qtyEl.style.display = inCart ? 'flex' : 'none';
    qtyEl.innerHTML = `
      <button class="dq-btn" onclick="changeQty('${dish.id}',-1)">−</button>
      <span class="dq-n">${inCart?inCart.qty:0}</span>
      <button class="dq-btn" onclick="changeQty('${dish.id}',1)">+</button>`;
    card.querySelector('.dish-body').appendChild(qtyEl);
  });
  updateCartUI();
};


</script>

