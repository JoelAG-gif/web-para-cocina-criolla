---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cocina Criolla — Restaurant</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Outfit:wght@300;400;500;600;700&family=Pacifico&display=swap" rel="stylesheet">
</head>
<body>

<div class="toast" id="toast"></div>

<!-- ===== NAV ===== -->
<nav id="nav">
  <a class="nav-logo" href="#">
    <div class="nav-logo-img"><img src="/images/logo.png" alt="Logo"></div>
    <div><div class="logo-main">Cocina Criolla</div><div class="logo-sub">Restaurant · Est. 2010</div></div>
  </a>
  <ul class="nav-links">
    <li><a href="#menu">Menú</a></li>
    <li><a href="#galeria">Galería</a></li>
    <li><a href="#resenas">Reseñas</a></li>
    <li><a href="#reservar">Reservar</a></li>
  </ul>
  <div class="nav-right">
    <a href="#reservar" class="nav-cta">🍽️ Reservar Mesa</a>
    <button class="hamburger" onclick="toggleDrawer()">☰</button>
  </div>
</nav>

<div class="nav-drawer" id="drawer">
  <a href="#menu" onclick="closeDrawer()">🍽️ Menú</a>
  <a href="#galeria" onclick="closeDrawer()">📸 Galería</a>
  <a href="#resenas" onclick="closeDrawer()">⭐ Reseñas</a>
  <a href="#reservar" onclick="closeDrawer()">📅 Reservar Mesa</a>
</div>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-collage">
    <div><img src="/images/lomo2.png" alt="Lomo Saltado"></div>
    <div><img src="/images/ceviche.png" alt="Ceviche Clásico"></div>
    <div><img src="/images/arroz_mare.png" alt="Arroz con Mariscos"></div>
    <div><img src="/images/aji_gallina.png" alt="Ají de Gallina"></div>
    <div><img src="/images/arroz_pato.png" alt="Arroz con Pato"></div>
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <div>
      <div class="hero-tag"><span class="htag-dot"></span>Comida Peruana Auténtica</div>
      <h1 class="hero-title">El sabor de<br>casa, <em>siempre.</em></h1>
      <p class="hero-desc">Más de 15 años sirviendo la cocina criolla peruana más auténtica. Ingredientes frescos, recetas tradicionales y el amor de siempre en cada plato.</p>
      <div class="hero-btns">
        <a href="#menu" class="btn-red">🍴 Ver Menú</a>
        <a href="#reservar" class="btn-outline">📅 Reservar Mesa →</a>
      </div>
    </div>
    <div class="hero-card">
      <div class="hc-stats">
        <div class="hcs"><div class="hcs-n">15+</div><div class="hcs-l">Años</div></div>
        <div class="hcs"><div class="hcs-n">4.9★</div><div class="hcs-l">Rating</div></div>
        <div class="hcs"><div class="hcs-n">5K+</div><div class="hcs-l">Clientes</div></div>
      </div>
      <div class="hc-dish"><img src="/images/ceviche.png" alt="Ceviche Clásico"></div>
      <div class="hc-lbl">🏆 Plato estrella — Ceviche Clásico</div>
    </div>
  </div>
</section>

<!-- STRIP -->
<div class="strip">
  <div class="strip-inner">
    <div class="strip-text">
      <div class="strip-lbl">Nuestra Historia</div>
      <div class="strip-title">Tradición familiar desde 2010</div>
      <div class="strip-desc">Nacimos con la misión de llevar la verdadera sazón criolla a tu mesa. Cada receta es un legado familiar preparado con ingredientes frescos del día.</div>
    </div>
    <div class="strip-badges">
      <div class="sb"><div class="sb-n">15+</div><div class="sb-l">Años de sabor</div></div>
      <div class="sb"><div class="sb-n">4.9★</div><div class="sb-l">En Google</div></div>
      <div class="sb"><div class="sb-n">5K+</div><div class="sb-l">Familias atendidas</div></div>
      <div class="sb"><div class="sb-n">🚗</div><div class="sb-l">Delivery diario</div></div>
    </div>
  </div>
</div>

<!-- FEATURES -->
<div class="features reveal">
  <div class="feat"><span class="feat-icon">🌿</span><div class="feat-title">Ingredientes Frescos</div><div class="feat-desc">Compramos diario en el mercado para garantizar frescura en cada plato</div></div>
  <div class="feat"><span class="feat-icon">👨‍🍳</span><div class="feat-title">Recetas Tradicionales</div><div class="feat-desc">Recetas heredadas de generación en generación con sazón auténtica</div></div>
  <div class="feat"><span class="feat-icon">🚗</span><div class="feat-title">Delivery Disponible</div><div class="feat-desc">Pedidos a domicilio por WhatsApp con entrega rápida y segura</div></div>
  <div class="feat"><span class="feat-icon">❤️</span><div class="feat-title">Hecho con Amor</div><div class="feat-desc">Cada plato preparado con la dedicación y pasión de siempre</div></div>
</div>

<!-- ===== MENU ===== -->
<div class="menu-bg" id="menu">
  <div class="menu-inner">
    <div class="reveal">
      <div class="sec-lbl">Nuestro Menú</div>
      <div class="sec-title">Los mejores <em>sabores</em> peruanos</div>
      <div class="sec-sub">Platos preparados con ingredientes frescos del día. El menú se actualiza según disponibilidad.</div>
    </div>
    <div class="menu-tabs" id="menuTabs">
      <button class="mtab active" data-cat="all">🍽️ Todo</button>
      <button class="mtab" data-cat="desayuno">☀️ Desayunos</button>
      <button class="mtab" data-cat="entradas">🥗 Entradas</button>
      <button class="mtab" data-cat="almuerzo">🍲 Almuerzos</button>
      <button class="mtab" data-cat="carta">⭐ A la Carta</button>
      <button class="mtab" data-cat="cena">🌙 Cenas</button>
      <button class="mtab" data-cat="bebidas">🥤 Bebidas</button>
    </div>
    <div class="menu-grid" id="menuGrid"></div>
  </div>
</div>

<!-- GALLERY -->
<div class="gal-bg" id="galeria">
  <div class="gal-inner">
    <div class="reveal">
      <div class="sec-lbl">Galería</div>
      <div class="sec-title">Nuestros <em>platos</em></div>
      <div class="sec-sub">Una muestra de lo que preparamos con amor cada día para ti.</div>
    </div>
    <div class="gal-grid">
      <div class="gi reveal"><img src="/images/lomo2.png" alt="Lomo Saltado"><div class="gi-ov"><div><div class="gi-lbl">Lomo Saltado</div><div class="gi-sub">El clásico infaltable</div></div></div></div>
      <div class="gi reveal"><img src="/images/ceviche.png" alt="Ceviche"><div class="gi-ov"><div><div class="gi-lbl">Ceviche Clásico</div><div class="gi-sub">Fresco y picantito</div></div></div></div>
      <div class="gi reveal"><img src="/images/arroz_mare.png" alt="Arroz con Mariscos"><div class="gi-ov"><div><div class="gi-lbl">Arroz con Mariscos</div><div class="gi-sub">Mar en cada bocado</div></div></div></div>
      <div class="gi reveal"><img src="/images/aji_gallina.png" alt="Ají de Gallina"><div class="gi-ov"><div><div class="gi-lbl">Ají de Gallina</div><div class="gi-sub">Cremoso y delicioso</div></div></div></div>
      <div class="gi reveal"><img src="/images/arroz_pato.png" alt="Arroz con Pato"><div class="gi-ov"><div><div class="gi-lbl">Arroz con Pato</div><div class="gi-sub">Norteño y sabroso</div></div></div></div>
    </div>
  </div>
</div>

<!-- REVIEWS -->
<div class="rev-bg" id="resenas">
  <div class="rev-inner">
    <div class="reveal">
      <div class="sec-lbl">Testimonios</div>
      <div class="sec-title">Lo que dicen <em>nuestros comensales</em></div>
      <div class="sec-sub">Más de 5,000 familias han disfrutado nuestra cocina.</div>
    </div>
    <div class="rev-grid">
      <div class="rc reveal">
        <div class="rc-top"><div class="rc-stars">★★★★★</div><div class="rc-badge">Cliente frecuente</div></div>
        <p class="rc-text">El mejor lomo saltado que he probado. La sazón es increíble, los ingredientes fresquísimos y la atención muy amable. Ya voy todos los domingos en familia.</p>
        <div class="rc-auth"><div class="rc-av">MR</div><div><div class="rc-name">María R.</div><div class="rc-date">Hace 1 semana · Google</div></div></div>
      </div>
      <div class="rc reveal">
        <div class="rc-top"><div class="rc-stars">★★★★★</div><div class="rc-badge">Delivery</div></div>
        <p class="rc-text">Pedí delivery y llegó en 30 minutos, calientito y perfecto. El ceviche estaba riquísimo, muy fresco. Definitivamente repetiré. 100% recomendado.</p>
        <div class="rc-auth"><div class="rc-av">CL</div><div><div class="rc-name">Carlos L.</div><div class="rc-date">Hace 2 semanas · Google</div></div></div>
      </div>
      <div class="rc reveal">
        <div class="rc-top"><div class="rc-stars">★★★★★</div><div class="rc-badge">Visita familiar</div></div>
        <p class="rc-text">Vine con toda la familia para el cumpleaños de mi mamá y quedamos encantados. El ají de gallina es exquisito y las porciones generosas.</p>
        <div class="rc-auth"><div class="rc-av">AP</div><div><div class="rc-name">Ana P.</div><div class="rc-date">Hace 3 semanas · Google</div></div></div>
      </div>
    </div>
    <div class="rating-box reveal">
      <div class="rb-big"><div class="rb-n">4.9</div><div class="rb-stars">★★★★★</div><div class="rb-lbl">528 reseñas en Google</div></div>
      <div style="width:1px;height:65px;background:var(--border)"></div>
      <div class="rb-bars">
        <div class="rb-row"><div class="rb-s">★★★★★</div><div class="rb-bar"><div class="rb-fill" style="width:88%"></div></div><div class="rb-pct">88%</div></div>
        <div class="rb-row"><div class="rb-s">★★★★☆</div><div class="rb-bar"><div class="rb-fill" style="width:10%"></div></div><div class="rb-pct">10%</div></div>
        <div class="rb-row"><div class="rb-s">★★★☆☆</div><div class="rb-bar"><div class="rb-fill" style="width:2%"></div></div><div class="rb-pct">2%</div></div>
      </div>
    </div>
  </div>
</div>

<!-- RESERVAR -->
<section class="res-sec" id="reservar">
  <div class="res-card reveal">
    <div class="res-img"><img src="/images/banner.png" alt="Restaurante"></div>
    <div class="res-body">
      <div class="res-lbl">Reservas & Delivery</div>
      <div class="res-title">¿Listo para disfrutar?</div>
      <div class="res-desc">Reserva tu mesa o haz tu pedido en segundos por WhatsApp. Confirmamos en menos de 5 minutos.</div>
      <div class="res-info">
        <div class="res-row"><div class="res-icon">📍</div>Av. La Marina 456, Lima</div>
        <div class="res-row"><div class="res-icon">🕐</div>Lun–Dom: 12:00pm – 9:00pm</div>
        <div class="res-row"><div class="res-icon">📱</div>+51 999 999 999</div>
        <div class="res-row"><div class="res-icon">🚗</div>Delivery disponible todo el día</div>
      </div>
      <a href="https://wa.me/51999999999?text=Hola!%20Quiero%20reservar%20en%20Cocina%20Criolla%20🍽️" target="_blank" class="wa-btn" onclick="showToast('Redirigiendo a WhatsApp...')">
        <svg viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Reservar / Pedir por WhatsApp
      </a>
    </div>
  </div>
  <div class="reveal">
    <div class="sec-lbl">Formulario</div>
    <div class="sec-title" style="margin-bottom:1.5rem">Reserva tu <em>mesa</em></div>
    <div class="form-row">
      <div class="ff"><label>Nombre</label><input type="text" placeholder="Tu nombre completo" id="fn"></div>
      <div class="ff"><label>Teléfono</label><input type="tel" placeholder="+51 999 999 999" id="fp"></div>
    </div>
    <div class="form-row">
      <div class="ff"><label>Fecha</label><input type="date" id="fd"></div>
      <div class="ff"><label>Hora</label><input type="time" id="fh" min="12:00" max="21:00"></div>
    </div>
    <div class="form-row">
      <div class="ff"><label>N° Personas</label>
        <select id="fp2"><option value="">Selecciona...</option><option>1 persona</option><option>2 personas</option><option>3-4 personas</option><option>5-6 personas</option><option>7 o más</option></select>
      </div>
      <div class="ff"><label>Tipo de pedido</label>
        <select id="ftipo"><option value="">Selecciona...</option><option>Mesa en local</option><option>Delivery a domicilio</option><option>Recoger en tienda</option></select>
      </div>
    </div>
    <div class="ff"><label>¿Qué deseas pedir? (opcional)</label><textarea id="fnote" placeholder="Ej: 2 lomos saltados, 1 ceviche..."></textarea></div>
    <button class="form-submit" onclick="sendReserva()">Enviar por WhatsApp 📲</button>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="foot-inner">
    <div class="foot-top">
      <div>
        <div class="ft-logo">
          <div class="ft-logo-img"><img src="/images/logo.png" alt="Logo"></div>
          <div><div class="logo-main" style="color:#fff">Cocina Criolla</div><div class="logo-sub">Restaurant · Est. 2010</div></div>
        </div>
        <p class="ft-desc">Más de 15 años llevando el sabor auténtico de la cocina peruana a tu mesa. Ingredientes frescos y recetas de siempre.</p>
      </div>
      <div>
        <div class="ft-ttl">Menú</div>
        <div class="ft-links">
          <a href="#menu">☀️ Desayunos</a>
          <a href="#menu">🥗 Entradas</a>
          <a href="#menu">🍲 Almuerzos</a>
          <a href="#menu">⭐ A la Carta</a>
          <a href="#menu">🥤 Bebidas</a>
        </div>
      </div>
      <div>
        <div class="ft-ttl">Información</div>
        <div class="ft-links">
          <a href="#">📍 Av. La Marina 456, Lima</a>
          <a href="#">🕐 Lun–Dom: 12pm – 9pm</a>
          <a href="#">📱 +51 999 999 999</a>
          <a href="#reservar">📅 Reservar Mesa</a>
          <a href="#resenas">⭐ Ver Reseñas</a>
        </div>
      </div>
    </div>
    <div class="foot-bottom"><span>© 2025 Cocina Criolla Restaurant. Todos los derechos reservados.</span><span>Diseñado con ❤️ para negocios locales</span></div>
  </div>
</footer>

<!-- ===== ADMIN PANEL ===== -->
<div class="admin-overlay" id="adminOverlay">
  <!-- LOGIN -->
  <div id="loginBox" class="login-box">
    <div class="login-logo">
      <span class="logo-main">Cocina Criolla</span>
      <p>Panel de Administración</p>
    </div>
    <div class="login-title">Iniciar Sesión</div>
    <div class="login-sub">Ingresa la contraseña del restaurante</div>
    <div class="login-err" id="loginErr">Contraseña incorrecta. Intenta de nuevo.</div>
    <div class="ff"><label>Contraseña</label><input type="password" id="adminPass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <button class="login-btn" onclick="doLogin()">Entrar al Panel →</button>
    <div style="text-align:center;margin-top:1rem;font-size:.72rem;color:var(--muted)">Contraseña por defecto: <strong>admin123</strong></div>
  </div>

  <!-- PANEL -->
  <div id="adminPanel" class="admin-modal" style="display:none">
    <div class="admin-header">
      <div class="admin-header-left">
        <div class="admin-icon">⚙️</div>
        <div>
          <div class="admin-title">Panel de Administración</div>
          <div class="admin-sub">Cocina Criolla Restaurant</div>
        </div>
      </div>
      <button class="admin-close" onclick="closeAdmin()">✕</button>
    </div>
    <div class="admin-tabs">
      <button class="atab active" onclick="showAdminTab('platos',this)">🍽️ Platos</button>
      <button class="atab" onclick="showAdminTab('secciones',this)">📋 Secciones</button>
      <button class="atab" onclick="showAdminTab('config',this)">🔧 Configuración</button>
    </div>
    <div class="admin-body" id="adminBody"></div>
  </div>
</div>



<!-- ===== CART BACKDROP ===== -->
<div class="cart-backdrop" id="cartBackdrop" onclick="closeCart()"></div>

<!-- ===== CART DRAWER ===== -->
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-header">
    <div class="cart-header-left">
      <div class="cart-icon">🛒</div>
      <div>
        <div class="cart-title">Tu Pedido</div>
        <div class="cart-count-badge" id="cartCountBadge">0 productos</div>
      </div>
    </div>
    <button class="cart-close" onclick="closeCart()">✕</button>
  </div>

  <!-- Tipo de servicio -->
  <div class="delivery-selector">
    <div class="ds-label">¿Cómo lo deseas?</div>
    <div class="ds-options">
      <div class="ds-opt selected" data-type="local" onclick="selectDeliveryType(this,'local')">
        <div class="ds-opt-icon">🍽️</div>
        <div class="ds-opt-label">Comer aquí</div>
      </div>
      <div class="ds-opt" data-type="delivery" onclick="selectDeliveryType(this,'delivery')">
        <div class="ds-opt-icon">🛵</div>
        <div class="ds-opt-label">Delivery</div>
      </div>
      <div class="ds-opt" data-type="recoger" onclick="selectDeliveryType(this,'recoger')">
        <div class="ds-opt-icon">🏃</div>
        <div class="ds-opt-label">Recoger</div>
      </div>
    </div>
    <div class="addr-field" id="addrField">
      <input type="text" id="deliveryAddr" class="cart-input" placeholder="📍 Tu dirección de entrega...">
    </div>
    <div class="time-field" id="timeField">
      <div class="time-field-grid" id="timeFieldGrid">
        <input type="date" id="cartDate" class="cart-input" placeholder="📅 Fecha">
        <input type="time" id="cartTime" class="cart-input" placeholder="🕒 Hora">
      </div>
    </div>
  </div>

  <!-- Items -->
  <div class="cart-items" id="cartItems">
    <div class="cart-empty">
      <div class="cart-empty-icon">🍽️</div>
      <div class="cart-empty-text">Tu pedido está vacío</div>
      <div class="cart-empty-sub">Agrega platos desde el menú</div>
    </div>
  </div>

  <!-- Footer -->
  <div class="cart-footer">
    <div class="cart-name-row">
      <input type="text" class="cart-input" id="cartName" placeholder="👤 Tu nombre *">
      <input type="tel" class="cart-input" id="cartPhone" placeholder="📱 Tu teléfono">
    </div>
    <div class="cart-note">
      <label>Nota adicional (opcional)</label>
      <textarea id="cartNote" placeholder="Sin picante, sin cebolla, etc..."></textarea>
    </div>
    <div class="cart-subtotal">
      <span id="cartItemCount">0 productos</span>
      <span id="cartSubtotal">S/. 0.00</span>
    </div>
    <div class="cart-total-row">
      <div class="cart-total-label">Total</div>
      <div class="cart-total-price" id="cartTotal">S/. 0.00</div>
    </div>
    <button class="cart-wa-btn" id="cartWaBtn" onclick="sendCartWA()" disabled>
